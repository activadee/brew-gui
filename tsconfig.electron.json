{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "outDir": "./dist-electron",
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["electron/**/*.ts", "src/shared/**/*.ts"]
}
